PORT=5000
NODE_ENV=development
# Local MongoDB (run: docker compose up -d from project root)
MONGO_URI=mongodb://127.0.0.1:27017/synctask-pro
# Or MongoDB Atlas: mongodb+srv://USER:PASS@cluster.mongodb.net/synctask-pro
JWT_SECRET=change_this_to_a_long_random_secret
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d
FRONTEND_URL=http://localhost:5173
